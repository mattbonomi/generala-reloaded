{
  "name": "Generala Reloaded",
  "description": "Anotador de Generala con reconocimiento de voz en español",
  "version": "2.0.0",
  "author": "Generala Team",
  "homepage": "/",
  "license": "MIT",
  "keywords": [
    "generala",
    "yahtzee",
    "dice",
